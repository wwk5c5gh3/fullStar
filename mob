#!/usr/bin/env bash
# mob-remote unified CLI — wraps mob-compose + tg-relay + term-bridge
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE="$ROOT/mob-compose/compose"

# Active terminal backend: TG_TERM_BACKEND env, else .env, else iterm.
term_backend() {
  local b="${TG_TERM_BACKEND:-}"
  if [[ -z "$b" && -f "$ROOT/.env" ]]; then
    b="$(grep -E '^[[:space:]]*TG_TERM_BACKEND=' "$ROOT/.env" | tail -1 | cut -d= -f2 | tr -d " \"'")"
  fi
  b="$(printf '%s' "${b:-iterm}" | tr '[:upper:]' '[:lower:]')"
  [[ "$b" == "terminal" ]] && echo terminal || echo iterm
}

cmd="${1:-}"
shift || true

case "$cmd" in
  up|tg-up|tg-all-start|start-tg)
    exec "$ROOT/tg-relay/tg-stack-daemon.sh" start "$@"
    ;;
  down|tg-down|tg-all-stop|stop-tg)
    exec "$ROOT/tg-relay/tg-stack-daemon.sh" stop "$@"
    ;;
  tg-start|listen)
    exec "$ROOT/tg-relay/tg-relay-daemon.sh" start "$@"
    ;;
  tg-stop)
    exec "$ROOT/tg-relay/tg-relay-daemon.sh" stop "$@"
    ;;
  tg-restart)
    exec "$ROOT/tg-relay/tg-relay-daemon.sh" restart "$@"
    ;;
  tg-status)
    exec "$ROOT/tg-relay/tg-stack-daemon.sh" status "$@"
    ;;
  tg-relay|tg-relay-once)
    exec python3 "$ROOT/tg-relay/run_tg_relay.py" "$@"
    ;;
  tg-setup|setup-telegram|setup-tg)
    exec "$ROOT/tg-relay/setup-telegram.sh" "$@"
    ;;
  tg-inbox)
    exec cat "$ROOT/inbox/pending.txt" 2>/dev/null || echo "(inbox empty)"
    ;;
  # Backend-aware (respect TG_TERM_BACKEND=iterm|terminal)
  inject|tg-iterm|term-inject)
    exec python3 "$ROOT/term-bridge/$(term_backend)-inject.py" "$@"
    ;;
  capture|term-capture)
    exec python3 "$ROOT/term-bridge/$(term_backend)-capture.py" "$@"
    ;;
  shot|term-screenshot)
    exec python3 "$ROOT/term-bridge/$(term_backend)-screenshot.py" "$@"
    ;;
  # Explicit iTerm backend
  iterm-inject)
    exec python3 "$ROOT/term-bridge/iterm-inject.py" "$@"
    ;;
  iterm-capture)
    exec python3 "$ROOT/term-bridge/iterm-capture.py" "$@"
    ;;
  iterm-screenshot)
    exec python3 "$ROOT/term-bridge/iterm-screenshot.py" "$@"
    ;;
  # Explicit Terminal.app backend
  terminal-inject)
    exec python3 "$ROOT/term-bridge/terminal-inject.py" "$@"
    ;;
  terminal-capture)
    exec python3 "$ROOT/term-bridge/terminal-capture.py" "$@"
    ;;
  terminal-screenshot)
    exec python3 "$ROOT/term-bridge/terminal-screenshot.py" "$@"
    ;;
  iterm-monitor|iterm-monitor-start|term-monitor)
    exec python3 "$ROOT/term-bridge/iterm-monitor.py" "$@"
    ;;
  iterm-extract|term-extract)
    exec python3 "$ROOT/term-bridge/iterm_extract.py" "$@"
    ;;
  iterm-list|term-list)
    exec python3 "$ROOT/term-bridge/iterm-list.py" "$@"
    ;;
  iterm-route|term-route)
    exec python3 "$ROOT/term-bridge/iterm_route.py" "$@"
    ;;
  iterm-buffer-setup|term-buffer-setup)
    exec python3 "$ROOT/term-bridge/iterm-buffer-setup.py" "$@"
    ;;
  iterm-monitor-once|term-monitor-once)
    exec python3 "$ROOT/term-bridge/iterm-monitor.py" --once --force "$@"
    ;;
  install-skill)
    exec "$ROOT/scripts/install-skill.sh" "$@"
    ;;
  ""|help|-h|--help)
    "$COMPOSE" help
    cat <<'EOF'

mob-remote extras:
  up             Start full TG stack (tg-relay + term-bridge monitor)
  down           Stop full TG stack
  tg-setup       One-click Telegram token + chat_id setup (--test)
  tg-start       Start tg-relay only (singleton daemon)
  tg-stop        Stop tg-relay only
  tg-restart     Stop duplicates and restart tg-relay daemon
  tg-status      Show tg-relay + term-bridge status + logs
  tg-relay-once  Run tg-relay once in foreground (debug)
  tg-inbox       Show pending natural-language tasks for Agent
  inject         Type text into active terminal (TG_TERM_BACKEND) — e.g. ./mob inject "hi"
  capture        Read active terminal output (--tail 50)
  shot           Capture active terminal window -> Telegram
  term-list      List iTerm windows/tabs for configuration
  term-extract   Preview assistant reply extracted for Telegram
  term-buffer-setup  Set iTerm2 unlimited scrollback (macOS)
  term-monitor   Poll terminal -> Telegram (assistant reply only)
  term-monitor-once  Extract latest reply and send once to TG
  install-skill  Install skills (composable: --only tg-notify,droid-ctl,iphone-ctl)
                 ./mob install-skill --list

Backend: TG_TERM_BACKEND=iterm|terminal selects target. inject/capture/shot and
  term-* follow it; force with iterm-inject / terminal-inject (also -capture / -screenshot).
EOF
    ;;
  *)
    exec "$COMPOSE" "$cmd" "$@"
    ;;
esac
